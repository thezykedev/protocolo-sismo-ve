---
import ContactSearch from '../components/ContactSearch';
import BranchSearch from '../components/BranchSearch';
import contacts from '../data/emergency-contacts.json';
import branches from '../data/red-cross-branches.json';
import Layout from '../layouts/Layout.astro';

const branchesWithPhone = branches.filter((branch) => branch.phones.length > 0);
const totalBranches = branchesWithPhone.length;
const statesCovered = new Set(branchesWithPhone.map((branch) => branch.state).filter(Boolean)).size;
const withPhone = branchesWithPhone.length;
const withEmail = branchesWithPhone.filter((branch) => branch.email).length;
---

<Layout
  title="Sismo VE"
  description="Contactos de emergencia para sismos en Venezuela, con Cruz Roja integrada, hospitales y apoyo vial."
  activeNav="contactos"
  pageTitle="Contactos"
  pageIntro="Números organizados por emergencias, ambulancias, bomberos, Protección Civil, seguridad, rescate, apoyo psicosocial, veterinario, Cruz Roja y hospitales. La guía de Cruz Roja queda integrada aquí para que no tengas que saltar entre páginas."
>
  <div class="contacts-toolbar">
    <ContactSearch client:load contacts={contacts} />
  </div>

  <section class="panel" id="cruz-roja">
    <p class="eyebrow">CRUZ ROJA VENEZOLANA</p>
    <p class="source-note">
      El directorio regional vive aquí, junto con el número para restablecer contacto entre
      familiares. Mantengo esta sección ordenada por acceso rápido, sin mapa, para que la lista
      sea más simple de recorrer.
    </p>

    <section class="grid-panel" aria-label="Accesos rápidos de la Cruz Roja Venezolana">
      <div class="info-block">
        <p class="eyebrow">CONTACTO ENTRE FAMILIARES</p>
        <p class="stat-value">0422 799 4880</p>
        <p>Cruza la línea para reportar pérdida de contacto con un familiar.</p>
        <a class="contact-action" href="tel:04227994880">Llamar</a>
      </div>
      <div class="info-block">
        <p class="eyebrow">CRUZ ROJA CARACAS</p>
        <p class="stat-value">0212 571 4380</p>
        <p>También disponible 0212 571 4713. Sede San Bernardino.</p>
        <div class="inline-actions">
          <a class="contact-action" href="tel:02125714380">Llamar</a>
          <a class="contact-action contact-action--muted" href="tel:02125714713">Alterno</a>
        </div>
      </div>
      <div class="info-block">
        <p class="eyebrow">{totalBranches} FILIALES</p>
        <p>
          Cubre {statesCovered} estados con datos de teléfono, dirección y correo.
        </p>
        <p>
          {withPhone} filiales tienen teléfono publicado y {withEmail} correo institucional.
        </p>
      </div>
    </section>

    <div class="contacts-toolbar">
      <BranchSearch client:load branches={branchesWithPhone} />
    </div>
  </section>
</Layout>
