---
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/600.css';
import '@fontsource/jetbrains-mono/700.css';
import BottomNav from '../components/BottomNav.astro';
import TopBar from '../components/TopBar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: 'inicio' | 'protocolos' | 'contactos' | 'mochila' | 'instalar';
  pageTitle?: string;
  pageIntro?: string;
  statusText?: string;
}

const {
  title = 'Sismo VE',
  description = 'Guía de emergencias para sismos en Venezuela, con contactos clave y acceso sin internet después de la primera carga.',
  activeNav = 'inicio',
  pageTitle,
  pageIntro,
  statusText = 'Preparando uso sin internet'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffff00" />
    <meta name="apple-mobile-web-app-title" content="Sismo VE" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
  </head>
  <body>
    <TopBar active={activeNav} statusText={statusText} />
    <div class="mobile-offline-banner" data-offline-banner aria-live="polite">
      <span class="mobile-offline-banner__dot" data-offline-dot aria-hidden="true"></span>
      <span data-offline-text>{statusText}</span>
    </div>
    <main class="page-shell">
      {
        pageTitle && (
          <section class="page-header">
            <p class="eyebrow">PROTOCOLO SÍSMICO</p>
            <h1>{pageTitle}</h1>
            {pageIntro && <p class="lede">{pageIntro}</p>}
          </section>
        )
      }
      <slot />
    </main>
    <BottomNav active={activeNav} />
    <script is:inline>
      (() => {
        const chips = Array.from(document.querySelectorAll('[data-offline-chip]'));
        const banner = document.querySelector('[data-offline-banner]');
        const bannerText = document.querySelector('[data-offline-text]');
        const bannerDot = document.querySelector('[data-offline-dot]');
        const storageKey = 'sismo-ve-offline-ready';

        const states = {
          ready: {
            text: 'Guardado para usar sin internet',
            tone: 'ready'
          },
          loading: {
            text: 'Preparando uso sin internet',
            tone: 'loading'
          },
          offline: {
            text: 'Funciona sin internet',
            tone: 'offline'
          }
        };

        const isReadyStored = () => {
          try {
            return localStorage.getItem(storageKey) === '1';
          } catch {
            return false;
          }
        };

        const markReadyStored = () => {
          try {
            localStorage.setItem(storageKey, '1');
          } catch {
            // ignore storage errors
          }
        };

        const setState = (state) => {
          const next = states[state] ?? states.loading;
          chips.forEach((chip) => {
            chip.dataset.offlineState = state;
            const text = chip.querySelector('[data-offline-text]');
            if (text) text.textContent = next.text;
          });

          if (banner) banner.dataset.offlineState = state;
          if (bannerText) bannerText.textContent = next.text;
          if (bannerDot) bannerDot.dataset.offlineTone = next.tone;
        };

        const update = () => {
          const online = navigator.onLine;
          const ready = isReadyStored();

          if (!online) {
            setState(ready ? 'offline' : 'loading');
            return;
          }

          setState(ready ? 'ready' : 'loading');
        };

        update();
        window.addEventListener('online', update);
        window.addEventListener('offline', update);

        if ('serviceWorker' in navigator) {
          navigator.serviceWorker.ready.then(() => {
            markReadyStored();
            update();
          }).catch(() => {});
          navigator.serviceWorker.addEventListener('controllerchange', update);
        }
      })();
    </script>
  </body>
</html>
