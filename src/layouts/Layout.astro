---
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/600.css';
import '@fontsource/jetbrains-mono/700.css';
import BottomNav from '../components/BottomNav.astro';
import TopBar from '../components/TopBar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: 'inicio' | 'protocolos' | 'contactos' | 'cruz-roja' | 'mochila' | 'instalar';
  pageTitle?: string;
  pageIntro?: string;
  statusText?: string;
}

const {
  title: _title,
  description = 'PWA offline de protocolos sísmicos para Venezuela.',
  activeNav = 'inicio',
  pageTitle,
  pageIntro,
  statusText = 'Modo offline listo'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffff00" />
    <meta name="apple-mobile-web-app-title" content="Sismo VE" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>Sismo VE</title>
  </head>
  <body>
    <TopBar active={activeNav} statusText={statusText} />
    <main class="page-shell">
      {
        pageTitle && (
          <section class="page-header">
            <p class="eyebrow">PROTOCOLO SÍSMICO</p>
            <h1>{pageTitle}</h1>
            {pageIntro && <p class="lede">{pageIntro}</p>}
          </section>
        )
      }
      <slot />
    </main>
    <BottomNav active={activeNav} />
  </body>
</html>
