---
import { navigationItems } from '../lib/navigation';

interface Props {
  active: string;
}

const { active } = Astro.props;
---

<nav
  class="bottom-nav"
  aria-label="Navegación principal"
  style={`--nav-columns: ${navigationItems.length}`}
>
  {
    navigationItems.map((item) => (
      <a class:list={[active === item.id && 'nav-active']} href={item.href}>
        <span class="nav-label">
          {item.icon === 'phone' && (
            <svg
              class="nav-label__icon"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M6.5 4.5h2.8l1.2 4.1-1.8 1.4c1 1.9 2.6 3.5 4.5 4.5l1.4-1.8 4.1 1.2v2.8c0 1.2-1 2.2-2.2 2.2C10.3 19 5 13.7 5 7.1c0-1.2 1-2.2 1.5-2.6z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          )}
          <span>{item.label}</span>
        </span>
      </a>
    ))
  }
</nav>
