---
import branches from '../data/red-cross-branches.json';

const dots = branches.map((b) => {
  const lng = b.coords.lng;
  const lat = b.coords.lat;
  const x = 24 + ((lng - -73.6) / (-59.7 - -73.6)) * (800 - 48);
  const y = 24 + ((12.6 - lat) / (12.6 - 0.6)) * (460 - 48);
  return { id: b.id, name: b.name, state: b.state, x, y, phone: b.phones.length > 0 };
});
