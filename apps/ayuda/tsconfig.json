{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "types": ["node", "geojson"],
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*",
    "svelte.config.js",
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/env.d.ts",
    ".svelte-kit/non-ambient.d.ts",
    ".svelte-kit/types/**/$types.d.ts"
  ]
}
